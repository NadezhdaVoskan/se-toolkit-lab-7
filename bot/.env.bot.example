# Telegram Bot Configuration
# Copy this file to .env.bot.secret and fill in the values

# Telegram bot token from BotFather (https://t.me/BotFather)
# Required for Telegram mode, not needed for --test mode
BOT_TOKEN=your-telegram-bot-token-here

# LMS Backend API
# Base URL of the backend (default: http://localhost:42002)
LMS_API_BASE_URL=http://localhost:42002

# LMS Backend API Key (Bearer token)
# Must match the LMS_API_KEY from .env.docker.secret
LMS_API_KEY=your-lms-api-key-here

# LLM API Configuration
# API key for the LLM service (Qwen Code or OpenRouter)
LLM_API_KEY=your-llm-api-key-here

# Base URL of the LLM API (default: http://localhost:42005/v1 for Qwen Code)
LLM_API_BASE_URL=http://localhost:42005/v1

# Model name to use (default: coder)
LLM_API_MODEL=coder
